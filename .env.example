# ========================================
# BOUNTY API - VARIABLES DE ENTORNO
# ========================================
# 
# Este archivo es un TEMPLATE - cópialo a .env y completa con valores reales
# NUNCA commitear .env con valores secretos
#

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================

# URI de conexión a MongoDB Atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/nombreBD
# 
# Pasos para obtenerla:
# 1. Ir a https://www.mongodb.com/cloud/atlas
# 2. Crear cluster (free tier available)
# 3. Cluster → Connect → Connect your application
# 4. Copiar connection string y reemplazar <password> e <database>
# 
# Ejemplo:
# MONGO_URI=mongodb+srv://capitanpirata:buccaneer123@bounty-cluster.a1b2c.mongodb.net/bounty-db
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/bounty-db

# ========================================
# CONFIGURACIÓN DE SERVIDOR
# ========================================

# Puerto en el que escucha el servidor
# Default: 3000
# En producción, puede ser diferente según infraestructura
PORT=3000

# Ambiente de ejecución
# Valores: development, production, testing
# - development: Logs detallados, hot reload
# - production: Optimizado, sin logs de debug
# - testing: Configurado para tests
NODE_ENV=development

# ========================================
# CONFIGURACIÓN LOGGING
# ========================================

# Nivel de logging
# Valores: debug, log, warn, error, verbose, fatal
# - debug: Todo incluido (muy detallado)
# - log: Información general
# - warn: Advertencias y errores
# - error: Solo errores críticos
# - verbose: Salida máxima (desarrollo)
LOG_LEVEL=debug

# ========================================
# CONFIGURACIÓN API
# ========================================

# Prefijo global para todas las rutas (opcional)
# Ejemplo: API_PREFIX=api/v1 → http://localhost:3000/api/v1/pirates
API_PREFIX=api/v1

# Permitir CORS (requiere corsOrigin abajo)
# Valores: true, false
CORS_ENABLED=true

# Origen permitido para CORS
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
CORS_ORIGIN=http://localhost:3000

# ========================================
# CONFIGURACIÓN VALIDACIÓN
# ========================================

# Habilitar validación global (class-validator)
# Default: true
ENABLE_VALIDATION=true

# Transformar tipos automáticamente
# Default: true (convierte strings a números, booleans, etc.)
ENABLE_TRANSFORM=true

# ========================================
# NOTAS DE SEGURIDAD
# ========================================
# 
# ⚠️ IMPORTANTE: Nunca compartir .env
# 
# Agregar a .gitignore:
# .env
# .env.local
# .env.*.local
# 
# Usar variables secretas en plataformas de hosting:
# - Vercel: Settings → Environment Variables
# - Heroku: Settings → Config Vars
# - Azure: Configuration → Application settings
# - AWS: Secrets Manager o Parameter Store
#
